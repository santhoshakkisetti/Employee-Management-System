-- =====================================================
-- TRIGGER
-- =====================================================

DELIMITER //

CREATE TRIGGER salary_validation

BEFORE INSERT ON employees

FOR EACH ROW

BEGIN

IF NEW.salary < 10000 THEN

SIGNAL SQLSTATE '45000'

SET MESSAGE_TEXT =
'Salary cannot be less than 10000';

END IF;

END //

DELIMITER ;

-- =====================================================
-- TEST QUERIES
-- =====================================================

-- View all employees

SELECT * FROM employees;

-- Employee with department

SELECT
e.first_name,
e.designation,
d.dept_name

FROM employees e

JOIN departments d
ON e.dept_id=d.dept_id;

-- Highest salary

SELECT *
FROM employees
ORDER BY salary DESC
LIMIT 1;

-- Average salary

SELECT AVG(salary)
AS AverageSalary
FROM employees;

-- Employee count department-wise

SELECT
d.dept_name,
COUNT(e.emp_id)

FROM departments d

LEFT JOIN employees e
ON d.dept_id=e.dept_id

GROUP BY d.dept_name;