-- =====================================================
-- VIEW
-- =====================================================

CREATE VIEW employee_summary AS

SELECT
e.emp_id,
e.first_name,
e.last_name,
e.designation,
e.salary,
d.dept_name

FROM employees e

JOIN departments d
ON e.dept_id=d.dept_id;

